{
  "name": "web-build-tools",
  "description": "Web build tools",
  "author": "Porky Ke",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/porky-prince/web-build-tools#readme",
  "repository": "git@github.com:porky-prince/web-build-tools",
  "bugs": "https://github.com/porky-prince/web-build-tools/issues",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "create": "tsx scripts/create.ts",
    "commitlint": "commitlint --from=main",
    "lint:prettier": "prettier \"{**/*,*}.{js,ts,json}\" --cache -l",
    "lint:code": "eslint --cache .",
    "lint": "npm-run-all -l -p \"lint:**\"",
    "pretest": "npm run lint",
    "test": "pnpm --filter \"*\" test",
    "build": "pnpm --filter \"*\" build",
    "pub:changeset": "changeset",
    "pub:release": "changeset publish"
  },
  "dependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.37.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.6.2",
    "del": "^8.0.1",
    "del-cli": "^7.0.0",
    "es-toolkit": "^1.46.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "fs-extra": "^11.3.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.4.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0"
  }
}
